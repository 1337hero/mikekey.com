---
import { socialLinks } from "../data/social";

const today = new Date();
const navItems = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/now", label: "Now" },
  { href: "/about", label: "About" },
];
---

<footer class="mt-auto border-t border-gray-200 dark:border-gray-700">
  <div class="container-content py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-12">
      <div class="md:col-span-6">
        <p class="font-display font-bold text-step-2 leading-fine text-pretty">
          Want to build<br />something<span class="text-bright-sun">?</span>
        </p>
        <a
          href="https://1337hero.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="meta-label mt-6 inline-block border border-gray-400 dark:border-gray-500 px-6 py-3 transition-colors duration-200 hover:bg-gray-900 hover:text-white hover:border-gray-900 dark:hover:bg-gray-100 dark:hover:text-gray-900 dark:hover:border-gray-100"
        >
          Hire Me ↗
        </a>
      </div>

      <nav class="md:col-span-3" aria-label="Footer">
        <p class="meta-label mb-4 text-gray-400">Index</p>
        <ul class="space-y-2">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="nav-link font-display text-base font-medium">{item.label}</a>
            </li>
          ))}
          <li>
            <a href="/rss.xml" class="nav-link font-display text-base font-medium">RSS</a>
          </li>
        </ul>
      </nav>

      <div class="md:col-span-3">
        <p class="meta-label mb-4 text-gray-400">Elsewhere</p>
        <ul class="space-y-2">
          {socialLinks.map((social) => (
            <li>
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="nav-link font-display text-base font-medium"
              >
                {social.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-gray-200 dark:border-gray-700 pt-8 font-mono text-xs text-gray-500 dark:text-gray-400">
      <p>&copy; 2006–{today.getFullYear()} Michael Key. All rights reserved.</p>
      <p class="mt-1">
        Crafted with care by <a href="https://1337hero.com" target="_blank" rel="author noopener noreferrer" class="nav-link">Mike Key (1337Hero)</a>.
      </p>
    </div>
  </div>
</footer>
