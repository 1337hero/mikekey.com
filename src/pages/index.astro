---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { Icon } from "astro-icon/components";
import HeroImg from "../assets/images/hero.png";
import { getCollection } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import { socialLinks } from "../data/social";
import { readingTime } from "../utils/readingTime";

const posts = (await getCollection("blog"))
  .sort((a, b) => (b.data.updatedDate ?? b.data.date).valueOf() - (a.data.updatedDate ?? a.data.date).valueOf())
  .slice(0, 5);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Hero
    title="Mike Key."
    subtitle="Going hard on local AI."
    description="Senior software engineer building local LLMs, AI agents, and custom tools — a notebook since 2006."
    alignment="center"
    backgroundImage={HeroImg.src}
  />

  <section class="py-12 md:py-16">
    <div class="container-content">
      <div class="flex items-end justify-between gap-6 mb-8 md:mb-10" data-reveal>
        <h2 class="font-display font-bold text-step-3">
          Latest<span class="text-bright-sun">.</span>
          <span class="meta-label ml-2 align-super text-gray-400">({String(posts.length).padStart(2, "0")})</span>
        </h2>
        <a href="/blog" class="nav-link meta-label mb-3 shrink-0">All Posts →</a>
      </div>

      <div class="border-t border-gray-200 dark:border-gray-700" data-reveal-group>
        {
          posts.map((post, i) => (
            <article data-reveal-item>
              <a
                href={`/blog/${post.id}/`}
                class="index-row group flex flex-col gap-2 border-b border-gray-200 dark:border-gray-700 py-5 md:flex-row md:items-baseline md:gap-8 md:py-6"
              >
                <span class="meta-label text-gray-400" aria-hidden="true">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="min-w-0 flex-1">
                  <h3 class="font-display font-bold text-step-1 transition-colors duration-200 group-hover:text-accent-safe">
                    {post.data.title}
                  </h3>
                  {post.data.description && (
                    <p class="mt-2 line-clamp-2 max-w-2xl font-serif text-step-min-1 text-gray-500 dark:text-gray-300">
                      {post.data.description}
                    </p>
                  )}
                </div>
                <div class="meta-label flex shrink-0 items-center gap-4 text-gray-400">
                  <FormattedDate date={post.data.date} />
                  <span aria-hidden="true">·</span>
                  <span>{readingTime(post.body)}&nbsp;min</span>
                  <span class="index-arrow text-accent-safe" aria-hidden="true">→</span>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 border-y border-gray-200 dark:border-gray-700 bg-gray-200/50 dark:bg-gray-900/60">
    <div class="container-content grid gap-8 md:grid-cols-12 md:gap-10">
      <p class="meta-label text-gray-400 md:col-span-3" data-reveal>
        <span class="mr-2 inline-block size-2 bg-royal-blue" aria-hidden="true"></span>About / The Notebook
      </p>
      <div class="md:col-span-9" data-reveal>
        <p class="font-display font-bold text-step-2 leading-fine text-pretty">
          A little corner of the internet where I've been
          <em class="font-serif font-normal text-accent-safe">writing</em>,
          <em class="font-serif font-normal text-accent-safe">tinkering</em>, and
          <em class="font-serif font-normal text-accent-safe">breaking things in public</em>
          since 2006.
        </p>
        <p class="mt-6 max-w-2xl font-serif text-step-min-1 text-gray-500 dark:text-gray-300">
          It's gone through a few lives already — WordPress in the early blogging days, Jekyll for that developer
          control, and now Astro, where I'm bringing old content back to life and mixing it with new ideas. Part
          personal journal, part public lab notebook.
        </p>
        <a href="/about" class="nav-link meta-label mt-6 inline-block">More About Me →</a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="container-content grid gap-8 md:grid-cols-12 md:gap-10">
      <p class="meta-label text-gray-400 md:col-span-3" data-reveal>
        <span class="mr-2 inline-block size-2 bg-cinnabar" aria-hidden="true"></span>Elsewhere
      </p>
      <ul class="border-t border-gray-200 dark:border-gray-700 md:col-span-9" data-reveal-group>
        {
          socialLinks.map((social) => (
            <li data-reveal-item>
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="index-row group flex items-center justify-between border-b border-gray-200 dark:border-gray-700 py-4"
              >
                <span class="flex items-center gap-4">
                  <Icon name={social.icon} size={22} aria-hidden="true" />
                  <span class="font-display font-bold text-step-1 transition-colors duration-200 group-hover:text-cinnabar-subdued">
                    {social.name}
                  </span>
                </span>
                <span class="index-arrow text-cinnabar-subdued" aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>
