---
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { href: "/blog", label: "Blog" },
  { href: "/now", label: "Now" },
  { href: "/about", label: "About" },
];
---

<header
  class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 flex flex-row justify-between items-center px-4 py-4 sm:px-8"
>
  <a href="/" class="font-display font-bold uppercase flex items-center" aria-label="Mike Key — home">
    <span>M</span>
    <span>K</span>
    <span class="text-bright-sun">.</span>
  </a>

  <nav class="flex items-center gap-3 sm:gap-6 font-display">
    {navItems.map((item, i) => (
      <HeaderLink href={item.href} class="nav-link text-sm sm:text-base font-medium">
        <span class="meta-label mr-1.5 hidden text-gray-400 md:inline" aria-hidden="true">0{i + 1}</span>
        {item.label}
      </HeaderLink>
    ))}
    <a
      href="https://1337hero.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="meta-label border border-gray-400 dark:border-gray-500 px-2.5 py-1.5 sm:px-4 sm:py-2 transition-colors duration-200 hover:bg-gray-900 hover:text-white hover:border-gray-900 dark:hover:bg-gray-100 dark:hover:text-gray-900 dark:hover:border-gray-100"
    >
      Hire&nbsp;Me&nbsp;↗
    </a>
    <ThemeToggle />
  </nav>
</header>
